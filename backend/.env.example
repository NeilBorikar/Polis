# App Settings
PROJECT_NAME="Polis API"
ENV="development"
DEBUG=true

# Database Settings
# For local development, sqlite is used. For AWS, you can change this to a PostgreSQL connection string.
# Example: postgresql://username:password@rds-endpoint.amazonaws.com:5432/polisdb
DATABASE_URL="sqlite:///./polis.db"

# CORS Settings
# A JSON-parsed list of origins that should be permitted to make cross-origin requests
CORS_ORIGINS='["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]'

# AWS Configuration (Optional, depending on services used)
AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# BUCKET_NAME=""
